{
  "name": "doc77",
  "version": "0.1.0",
  "description": "Doc77 CLI — 默认安全、对话驱动的智能本地文档管理 Agent",
  "license": "MIT",
  "repository": "github:xyy277/doc77",
  "keywords": ["doc77", "document", "manager", "mcp", "cli", "agent"],
  "files": ["dist"],
  "preferGlobal": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "doc77": "./dist/bin/doc77.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@doc77/core": "workspace:*",
    "@doc77/mcp": "workspace:*",
    "@doc77/ai": "workspace:*"
  }
}
