{
  "name": "@doc77/cli",
  "version": "0.5.2",
  "description": "Doc77 CLI — 默认安全、对话驱动的智能本地文档管理 Agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xyy277/doc77.git"
  },
  "keywords": [
    "doc77",
    "document",
    "manager",
    "mcp",
    "cli",
    "agent"
  ],
  "files": [
    "dist"
  ],
  "preferGlobal": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/bin/doc77.js": {
      "import": "./dist/bin/doc77.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "doc77": "dist/bin/doc77.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@doc77/core": "workspace:^"
  },
  "peerDependencies": {
    "@doc77/mcp": "workspace:^",
    "@doc77/ai": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@doc77/mcp": {
      "optional": true
    },
    "@doc77/ai": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
