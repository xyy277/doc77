{
  "name": "@doc77/core",
  "version": "0.2.2",
  "description": "Doc77 核心引擎 — 数据库、文件系统抽象层、预览引擎、Express Server",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xyy277/doc77.git"
  },
  "keywords": [
    "doc77",
    "document",
    "manager",
    "mcp",
    "preview"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup && node -e \"require('fs').cpSync('src/web','dist/web',{recursive:true})\"",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^5.1.0",
    "marked": "^17.0.0",
    "pino": "^9.0.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0"
  }
}
