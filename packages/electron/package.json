{
  "name": "@doc77/electron",
  "version": "1.0.4",
  "description": "Doc77 Desktop — Electron desktop app for local document preview",
  "author": "xyy277 <907507646@qq.com>",
  "license": "MIT",
  "repository": "https://github.com/xyy277/doc77",
  "main": "dist/main.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build": "npm run build:main && npm run build:preload && node scripts/verify-no-static-core.cjs",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@doc77/core": "workspace:^",
    "electron-updater": "^6.8.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.8.0"
  }
}
