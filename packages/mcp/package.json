      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@doc77/core": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.4.0"
