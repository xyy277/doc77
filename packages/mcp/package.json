{
  "name": "@doc77/mcp",
  "version": "0.7.2",
  "description": "Doc77 MCP 服务层 — MCP 协议实现、安全校验、操作队列、事务系统",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xyy277/doc77.git"
  },
  "keywords": [
    "doc77",
    "mcp",
    "protocol",
    "tools"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
